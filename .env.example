# ExplainLens Environment Variables
# Copy this file to .env and fill in values if needed.
# Current MVP does not require any API keys.
# Future phases will use these:

# OpenAI API (Phase 3: LLM plugin)
# OPENAI_API_KEY=sk-...

# Image generation API (Phase 4)
# IMAGE_GEN_API_KEY=...
# IMAGE_GEN_API_URL=...

# Log level
LOG_LEVEL=INFO
